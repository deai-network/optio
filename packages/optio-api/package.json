{
  "name": "optio-api",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "description": "Server-side optio API with Fastify, Express, and Next.js adapters.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deai-network/optio.git",
    "directory": "packages/optio-api"
  },
  "homepage": "https://github.com/deai-network/optio/tree/main/packages/optio-api#readme",
  "bugs": { "url": "https://github.com/deai-network/optio/issues" },
  "author": "Kristof Csillag <kristof.csillag@deai-labs.com>",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./fastify": {
      "import": "./dist/adapters/fastify.js",
      "types": "./dist/adapters/fastify.d.ts"
    },
    "./express": {
      "import": "./dist/adapters/express.js",
      "types": "./dist/adapters/express.d.ts"
    },
    "./nextjs/pages": {
      "import": "./dist/adapters/nextjs-pages.js",
      "types": "./dist/adapters/nextjs-pages.d.ts"
    },
    "./nextjs/app": {
      "import": "./dist/adapters/nextjs-app.js",
      "types": "./dist/adapters/nextjs-app.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --max-warnings=0"
  },
  "dependencies": {
    "@clamator/over-redis": "^0.1.9",
    "@clamator/protocol": "^0.1.9",
    "@fastify/http-proxy": "^11.0.0",
    "@ts-rest/core": "^3.51.0",
    "ioredis": "^5.4.0",
    "mongodb": "^6.12.0",
    "optio-contracts": "workspace:*",
    "zod": "^3"
  },
  "optionalDependencies": {
    "@ts-rest/fastify": "^3.51.0"
  },
  "peerDependencies": {
    "express": "^4.21.0 || ^5.0.0",
    "fastify": "^5.2.0",
    "next": "^13.0.0 || ^14.0.0 || ^15.0.0"
  },
  "peerDependenciesMeta": {
    "fastify": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ts-rest/express": "^3.52.1",
    "@ts-rest/next": "^3.52.1",
    "@ts-rest/serverless": "^3.52.1",
    "@types/express": "^5.0.6",
    "@types/ioredis-mock": "^8.2.7",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.0",
    "eslint": "^10.3.0",
    "express": "^5.2.1",
    "ioredis-mock": "^8.13.1",
    "mongodb-memory-server": "^11.0.1",
    "next": "^16.2.1",
    "node-mocks-http": "^1.17.2",
    "supertest": "^7.2.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "^3.0.0",
    "ws": "^8.18.0"
  }
}
