{
  "name": "optio-api",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./fastify": {
      "import": "./dist/adapters/fastify.js",
      "types": "./dist/adapters/fastify.d.ts"
    },
    "./express": {
      "import": "./dist/adapters/express.js",
      "types": "./dist/adapters/express.d.ts"
    },
    "./nextjs/pages": {
      "import": "./dist/adapters/nextjs-pages.js",
      "types": "./dist/adapters/nextjs-pages.d.ts"
    },
    "./nextjs/app": {
      "import": "./dist/adapters/nextjs-app.js",
      "types": "./dist/adapters/nextjs-app.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/http-proxy": "^11.0.0",
    "@ts-rest/core": "^3.51.0",
    "ioredis": "^5.4.0",
    "mongodb": "^6.12.0",
    "optio-contracts": "workspace:*"
  },
  "optionalDependencies": {
    "@ts-rest/fastify": "^3.51.0"
  },
  "peerDependencies": {
    "express": "^4.21.0 || ^5.0.0",
    "fastify": "^5.2.0",
    "next": "^13.0.0 || ^14.0.0 || ^15.0.0"
  },
  "peerDependenciesMeta": {
    "fastify": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ts-rest/express": "^3.52.1",
    "@ts-rest/next": "^3.52.1",
    "@ts-rest/serverless": "^3.52.1",
    "@types/express": "^5.0.6",
    "@types/ioredis-mock": "^8.2.7",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.0",
    "express": "^5.2.1",
    "ioredis-mock": "^8.13.1",
    "mongodb-memory-server": "^11.0.1",
    "next": "^16.2.1",
    "node-mocks-http": "^1.17.2",
    "supertest": "^7.2.2",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "ws": "^8.18.0"
  }
