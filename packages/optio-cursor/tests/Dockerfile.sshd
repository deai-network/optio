FROM linuxserver/openssh-server:latest
# optio-cursor runs cursor-agent inside a detached tmux session fronted by
# ttyd, so the "remote" needs bash (the launch wrappers use `bash -lc`/
# `bash -c`), tmux, and python3 (the fake-cursor shim). ttyd is provided by
# the mounted shim.
RUN apk add --no-cache python3 tmux bash
